# Use synthetic data instead of the real backend (no MQTT required).
# Set to "true" for offline UI development.
VITE_USE_MOCK=false

# Backend origin used by the dev server proxy for /api, /ws, /stream.
# Only matters in dev (vite serves the SPA itself); in prod nginx is the proxy.
VITE_BACKEND_URL=http://127.0.0.1:1111
