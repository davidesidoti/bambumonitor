# ─────────────────────────────────────────────
# Bambu Monitor backend configuration
# Copy to backend/.env and fill in values for your printer.
# ─────────────────────────────────────────────

# IP address of the printer on the LAN (LAN-only mode must be enabled).
PRINTER_IP=192.168.1.100

# Printer serial number, visible in Bambu Studio or on the device label.
PRINTER_SERIAL=01P00A000000000

# LAN access code shown on the printer's display under Settings > Network.
PRINTER_ACCESS_CODE=12345678

# SQLite database file. Async driver, do not change unless you know why.
DATABASE_URL=sqlite+aiosqlite:///./bambu.db

# Logging: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# WebSocket path served by FastAPI (must match the nginx /ws proxy).
WS_PATH=/ws

# URL of the local ustreamer instance (only used by health checks for now).
USTREAMER_URL=http://127.0.0.1:8080

# Enable verbose log formatting for development. Set to "false" in prod.
DEV_MODE=true
